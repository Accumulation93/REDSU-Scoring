page {
  min-height: 100%;
  background:
    radial-gradient(circle at 12% 10%, rgba(96, 165, 250, 0.16) 0%, transparent 26%),
    radial-gradient(circle at 86% 18%, rgba(191, 219, 254, 0.22) 0%, transparent 24%),
    radial-gradient(circle at 18% 88%, rgba(125, 211, 252, 0.10) 0%, transparent 22%),
    linear-gradient(135deg, #f8fbff 0%, #f1f6fc 48%, #edf3fa 100%);
  color: #1f2a37;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
}

button,
input,
textarea,
picker,
view,
text,
scroll-view {
  font-family: "PingFang SC", "HarmonyOS Sans SC", "Microsoft YaHei", sans-serif;
}

.page {
  position: relative;
  min-height: 100vh;
  padding: 30rpx 24rpx 42rpx;
  box-sizing: border-box;
}

.page::before {
  content: "";
  position: fixed;
  top: -120rpx;
  right: -90rpx;
  width: 320rpx;
  height: 320rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(96, 165, 250, 0.18) 0%, rgba(96, 165, 250, 0) 72%);
  pointer-events: none;
}

.page::after {
  content: "";
  position: fixed;
  left: -120rpx;
  bottom: 150rpx;
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(147, 197, 253, 0.16) 0%, rgba(147, 197, 253, 0) 72%);
  pointer-events: none;
}

.hero {
  position: relative;
  overflow: hidden;
  margin-bottom: 28rpx;
  padding: 44rpx 34rpx 40rpx;
  border-radius: 38rpx;
  background:
    linear-gradient(135deg, rgba(37, 99, 235, 0.98) 0%, rgba(59, 130, 246, 0.95) 42%, rgba(96, 165, 250, 0.90) 100%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.10), rgba(255, 255, 255, 0));
  border: 1rpx solid rgba(255, 255, 255, 0.24);
  box-shadow:
    0 24rpx 54rpx rgba(37, 99, 235, 0.22),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.24);
  animation: glassFadeUp 0.42s ease both;
}


.hero::before {
  content: "";
  position: absolute;
  top: -90rpx;
  right: -35rpx;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.14);
}

.hero::after {
  content: "";
  position: absolute;
  left: -90rpx;
  bottom: -120rpx;
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
}

.hero-badge,
.hero-title,
.hero-subtitle {
  position: relative;
  z-index: 1;
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 18rpx;
  padding: 10rpx 24rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.22) 0%, rgba(255, 255, 255, 0.14) 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.28);
  color: #f8fbff;
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
  backdrop-filter: blur(14rpx);
  -webkit-backdrop-filter: blur(14rpx);
}

.hero-title {
  color: #ffffff;
  font-size: 50rpx;
  font-weight: 700;
  line-height: 1.24;
  letter-spacing: 1rpx;
  text-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.08);
}

.hero-subtitle {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.92);
  font-size: 26rpx;
  line-height: 1.72;
}

.tabs-card,
.card {
  position: relative;
  margin-bottom: 24rpx;
  padding: 28rpx 26rpx;
  border-radius: 30rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.80) 0%, rgba(248, 251, 255, 0.72) 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.62);
  box-shadow:
    0 18rpx 36rpx rgba(15, 23, 42, 0.06),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.78);
  backdrop-filter: blur(24rpx);
  -webkit-backdrop-filter: blur(24rpx);
  box-sizing: border-box;
  animation: glassFadeUp 0.46s ease both;
}

.card + .card {
  margin-top: 2rpx;
}

.tabs-card {
  display: flex;
  gap: 16rpx;
  padding: 16rpx;
}

.feature-tab {
  position: relative;
  flex: 1;
  overflow: hidden;
  padding: 24rpx 16rpx;
  border-radius: 24rpx;
  text-align: center;
  color: #53708e;
  font-size: 26rpx;
  font-weight: 700;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.92) 0%, rgba(246, 249, 255, 0.82) 100%);
  border: 1rpx solid rgba(219, 229, 241, 0.92);
  transition: transform 0.18s ease, box-shadow 0.24s ease, color 0.24s ease, background 0.24s ease;
}

.feature-tab::after {
  content: "";
  position: absolute;
  inset: -30%;
  background: radial-gradient(circle, rgba(96, 165, 250, 0.22) 0%, rgba(96, 165, 250, 0) 60%);
  opacity: 0;
  transition: opacity 0.24s ease;
}

.feature-tab-active {
  color: #ffffff;
  background: linear-gradient(135deg, #2563eb 0%, #3b82f6 44%, #60a5fa 100%);
  box-shadow:
    0 18rpx 34rpx rgba(37, 99, 235, 0.18),
    0 0 24rpx rgba(96, 165, 250, 0.14);
}

.feature-tab-active::after {
  opacity: 1;
}

.feature-tab:active,
.card:active,
.info-block:active,
.target-card:active {
  transform: translateY(1rpx) scale(0.992);
}

.panel {
  opacity: 1;
  animation: panelGlowIn 0.32s ease both;
}

.panel-active {
  opacity: 1;
}

.activity-card {
  overflow: hidden;
}

.activity-card::before {
  content: "";
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(59, 130, 246, 0.10) 0%, rgba(191, 219, 254, 0.05) 52%, rgba(255, 255, 255, 0) 100%);
  pointer-events: none;
}

.targets-card {
  padding-bottom: 20rpx;
}

.profile-card {
  overflow: hidden;
}

.profile-card::before {
  content: "";
  position: absolute;
  top: -120rpx;
  right: -80rpx;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(14, 165, 233, 0.18) 0%, rgba(14, 165, 233, 0) 70%);
  pointer-events: none;
}

.activity-name {
  position: relative;
  z-index: 1;
  margin-top: 6rpx;
  margin-bottom: 10rpx;
  padding: 8rpx 4rpx 6rpx;
  color: #0f172a;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.48;
  letter-spacing: 0.2rpx;
  word-break: break-word;
}

.activity-name::after {
  content: "";
  display: block;
  width: 72rpx;
  height: 4rpx;
  margin-top: 12rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, rgba(59, 130, 246, 0.46), rgba(59, 130, 246, 0.08));
}

.activity-desc {
  position: relative;
  z-index: 1;
  margin-top: 2rpx;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, rgba(250, 252, 255, 0.94) 0%, rgba(245, 248, 255, 0.86) 100%);
  border: 1rpx solid rgba(226, 232, 240, 0.52);
  color: #64748b;
  font-size: 24rpx;
  line-height: 1.8;
}

.info-head {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.section-title {
  position: relative;
  padding-left: 20rpx;
  color: #0f172a;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.4;
  letter-spacing: 0.2rpx;
}

.section-title::before {
  content: "";
  position: absolute;
  left: 0;
  top: 8rpx;
  width: 8rpx;
  height: 28rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #2563eb 0%, #60a5fa 100%);
  box-shadow: 0 0 14rpx rgba(59, 130, 246, 0.24);
}

.mode-chip {
  flex-shrink: 0;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, rgba(239, 246, 255, 0.98) 0%, rgba(219, 234, 254, 0.90) 100%);
  border: 1rpx solid rgba(147, 197, 253, 0.8);
  color: #1d4ed8;
  font-size: 22rpx;
  font-weight: 700;
}

.mode-chip-audit {
  background: linear-gradient(135deg, rgba(255, 247, 237, 0.98) 0%, rgba(254, 215, 170, 0.88) 100%);
  border-color: rgba(251, 191, 36, 0.72);
  color: #c2410c;
}

.mode-chip-readonly {
  background: linear-gradient(135deg, rgba(241, 245, 249, 0.96) 0%, rgba(226, 232, 240, 0.88) 100%);
  border-color: rgba(148, 163, 184, 0.72);
  color: #475569;
}

.profile-banner,
.profile-status,
.readonly-tip {
  position: relative;
  z-index: 1;
  margin-bottom: 18rpx;
  padding: 20rpx 22rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, rgba(250, 252, 255, 0.94) 0%, rgba(245, 248, 255, 0.86) 100%);
  border: 1rpx solid rgba(226, 232, 240, 0.56);
  color: #64748b;
  font-size: 24rpx;
  line-height: 1.78;
}

.status-title {
  color: #0f172a;
  font-size: 28rpx;
  font-weight: 700;
}

.status-desc {
  margin-top: 8rpx;
}

.field-grid,
.info-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 20rpx;
}

.info-block {
  width: calc(50% - 10rpx);
  padding: 24rpx 22rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.92) 0%, rgba(248, 251, 255, 0.80) 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.68);
  box-shadow:
    0 10rpx 24rpx rgba(15, 23, 42, 0.035),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.78);
  box-sizing: border-box;
}

.info-block-full {
  width: 100%;
  background: linear-gradient(135deg, rgba(239, 246, 255, 0.6) 0%, rgba(219, 234, 254, 0.4) 100%);
  border: 1rpx solid rgba(191, 219, 254, 0.6);
}

.info-label {
  margin-bottom: 10rpx;
  color: #64748b;
  font-size: 23rpx;
  line-height: 1.5;
}

.info-value {
  color: #0f172a;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.5;
  word-break: break-all;
}

.profile-form {
  margin-top: 10rpx;
}

.profile-field {
  margin-bottom: 22rpx;
}

.profile-field-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.profile-field-title {
  position: relative;
  padding-left: 16rpx;
  color: #16324f;
  font-size: 27rpx;
  font-weight: 700;
  line-height: 1.5;
  letter-spacing: 0.2rpx;
}

.profile-field-title::before {
  content: "";
  position: absolute;
  left: 0;
  top: 9rpx;
  width: 6rpx;
  height: 24rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #38bdf8 0%, #2563eb 100%);
  box-shadow: 0 0 12rpx rgba(59, 130, 246, 0.18);
}

.field-required {
  margin-left: 6rpx;
  color: #ef4444;
  font-size: 24rpx;
  font-weight: 800;
}

.profile-field-type {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, rgba(239, 246, 255, 0.96) 0%, rgba(219, 234, 254, 0.86) 100%);
  border: 1rpx solid rgba(191, 219, 254, 0.82);
  color: #2563eb;
  font-size: 20rpx;
  font-weight: 700;
  box-shadow:
    0 8rpx 18rpx rgba(37, 99, 235, 0.06),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.84);
}

.field-input,
.picker-value {
  width: 100%;
  min-height: 90rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  border-radius: 24rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.94) 0%, rgba(247, 250, 255, 0.84) 100%);
  border: 1rpx solid rgba(226, 232, 240, 0.74);
  color: #0f172a;
  font-size: 25rpx;
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.82),
    0 8rpx 18rpx rgba(15, 23, 42, 0.03);
}

.field-hint {
  margin-top: 10rpx;
  color: #64748b;
  font-size: 22rpx;
  line-height: 1.7;
}

.profile-submit-btn {
  position: relative;
  overflow: hidden;
  margin-top: 16rpx;
  min-height: 96rpx;
  line-height: 96rpx;
  border-radius: 28rpx;
  font-size: 29rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
  box-shadow:
    0 24rpx 40rpx rgba(37, 99, 235, 0.20),
    0 0 30rpx rgba(96, 165, 250, 0.16),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.28);
}

.profile-submit-btn::before {
  content: "";
  position: absolute;
  top: 0;
  left: -120%;
  width: 72%;
  height: 100%;
  background: linear-gradient(90deg, rgba(255, 255, 255, 0) 0%, rgba(255, 255, 255, 0.24) 50%, rgba(255, 255, 255, 0) 100%);
}

.profile-submit-btn-audit {
  background: linear-gradient(135deg, #0284c7 0%, #2563eb 52%, #60a5fa 100%);
}

.target-state {
  padding: 36rpx 20rpx;
  text-align: center;
  color: #94a3b8;
  font-size: 25rpx;
  line-height: 1.7;
}

.target-scroll {
  max-height: 640rpx;
}

.target-card {
  position: relative;
  margin-bottom: 18rpx;
  padding: 24rpx 22rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.92) 0%, rgba(249, 251, 255, 0.82) 100%);
  border: 1rpx solid rgba(226, 237, 247, 0.96);
  box-shadow:
    0 12rpx 24rpx rgba(15, 23, 42, 0.04),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.78);
  box-sizing: border-box;
}

.target-card:last-child {
  margin-bottom: 4rpx;
}

.target-card-active {
  background: linear-gradient(135deg, rgba(239, 246, 255, 0.98) 0%, rgba(219, 234, 254, 0.90) 100%);
  border-color: rgba(96, 165, 250, 0.95);
  box-shadow: 0 18rpx 32rpx rgba(37, 99, 235, 0.11);
}

.target-card-active::after {
  content: "";
  position: absolute;
  top: 22rpx;
  right: 22rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: linear-gradient(180deg, #3b82f6 0%, #60a5fa 100%);
  box-shadow: 0 0 0 8rpx rgba(59, 130, 246, 0.12);
}

.target-main {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 12rpx;
  padding-right: 28rpx;
}

.target-name {
  color: #0f172a;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.4;
}

.target-tags {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  flex-wrap: wrap;
  gap: 10rpx;
}

.target-identity,
.target-status {
  flex-shrink: 0;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.target-identity {
  background: linear-gradient(135deg, rgba(239, 246, 255, 0.96) 0%, rgba(219, 234, 254, 0.88) 100%);
  color: #2563eb;
  border: 1rpx solid rgba(147, 197, 253, 0.74);
}

.target-status-pending {
  background: linear-gradient(135deg, rgba(255, 247, 237, 0.96) 0%, rgba(254, 215, 170, 0.88) 100%);
  color: #c2410c;
  border: 1rpx solid rgba(251, 191, 36, 0.62);
}

.target-status-scored {
  background: linear-gradient(135deg, rgba(236, 253, 245, 0.96) 0%, rgba(187, 247, 208, 0.88) 100%);
  color: #15803d;
  border: 1rpx solid rgba(74, 222, 128, 0.62);
}

.target-meta {
  margin-top: 6rpx;
  color: #64748b;
  font-size: 23rpx;
  line-height: 1.62;
}

.empty-card {
  padding-top: 56rpx;
  padding-bottom: 56rpx;
  text-align: center;
}

.profile-empty {
  margin-top: 12rpx;
}

.empty-title {
  color: #0f172a;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.5;
}

.empty-desc {
  margin-top: 14rpx;
  color: #64748b;
  font-size: 25rpx;
  line-height: 1.72;
}

.actions {
  margin-top: 14rpx;
  padding-bottom: 12rpx;
}

.actions button {
  position: relative;
  overflow: hidden;
  height: 94rpx;
  line-height: 94rpx;
  margin-bottom: 20rpx;
  border: none;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 700;
  letter-spacing: 0.5rpx;
  box-shadow:
    0 16rpx 30rpx rgba(15, 23, 42, 0.06),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.24);
}

.actions button::after {
  border: none;
}

.actions button::before {
  content: "";
  position: absolute;
  top: 0;
  left: -120%;
  width: 72%;
  height: 100%;
  background: linear-gradient(90deg, rgba(255, 255, 255, 0) 0%, rgba(255, 255, 255, 0.24) 50%, rgba(255, 255, 255, 0) 100%);
}

.primary-btn {
  background: linear-gradient(135deg, #2563eb 0%, #3b82f6 45%, #60a5fa 100%);
  color: #ffffff;
  box-shadow:
    0 20rpx 34rpx rgba(37, 99, 235, 0.20),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.24);
}

.secondary-btn {
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.96) 0%, rgba(246, 249, 255, 0.88) 100%);
  color: #1e293b;
  border: 1rpx solid rgba(219, 229, 241, 0.96);
  box-shadow:
    0 10rpx 22rpx rgba(15, 23, 42, 0.05),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.84);
}

.danger-btn {
  background: linear-gradient(135deg, #ef4444 0%, #f87171 100%);
  color: #ffffff;
  box-shadow:
    0 16rpx 30rpx rgba(239, 68, 68, 0.16),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.18);
}

.primary-btn:active,
.secondary-btn:active,
.danger-btn:active {
  transform: translateY(2rpx) scale(0.985);
  opacity: 0.94;
  filter: saturate(1.03);
}

.dialog-layer {
  position: fixed;
  inset: 0;
  z-index: 99;
}

.dialog-mask {
  position: absolute;
  inset: 0;
  background: rgba(15, 23, 42, 0.34);
  backdrop-filter: blur(6rpx);
  -webkit-backdrop-filter: blur(6rpx);
}

.dialog-panel {
  position: absolute;
  left: 56rpx;
  right: 56rpx;
  top: 50%;
  transform: translateY(-50%);
  padding: 28rpx 26rpx 24rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.95) 0%, rgba(248, 251, 255, 0.9) 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.82);
  box-shadow: 0 22rpx 44rpx rgba(15, 23, 42, 0.14);
}

.dialog-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, rgba(254, 226, 226, 0.94) 0%, rgba(254, 202, 202, 0.86) 100%);
  color: #dc2626;
  font-size: 22rpx;
  font-weight: 700;
}

.dialog-title {
  margin-top: 18rpx;
  color: #0f172a;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.4;
}

.dialog-desc {
  margin-top: 12rpx;
  color: #64748b;
  font-size: 24rpx;
  line-height: 1.72;
}

.dialog-actions {
  display: flex;
  gap: 14rpx;
  margin-top: 24rpx;
}

.dialog-btn {
  flex: 1;
  height: 82rpx !important;
  line-height: 82rpx !important;
  margin-bottom: 0 !important;
  border-radius: 18rpx !important;
  font-size: 26rpx !important;
}

.hero-title,
.hero-subtitle,
.activity-desc,
.info-value,
.target-name,
.target-meta,
.empty-title,
.empty-desc,
.status-title,
.status-desc,
.profile-banner,
.readonly-tip,
.field-hint {
  word-break: break-word;
}

@keyframes glassFadeUp {
  from {
    opacity: 0;
    transform: translateY(18rpx);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes panelGlowIn {
  from {
    opacity: 0;
    transform: translateY(10rpx);
    filter: saturate(0.92);
  }

  to {
    opacity: 1;
    transform: translateY(0);
    filter: saturate(1);
  }
}

@media (max-width: 360px) {
  .page {
    padding-left: 20rpx;
    padding-right: 20rpx;
  }

  .hero {
    padding: 34rpx 26rpx 30rpx;
  }

  .hero-title {
    font-size: 42rpx;
  }

  .tabs-card {
    flex-direction: column;
  }

  .info-block {
    width: 100%;
  }

  .target-main {
    flex-direction: column;
    align-items: flex-start;
    padding-right: 0;
  }
}
