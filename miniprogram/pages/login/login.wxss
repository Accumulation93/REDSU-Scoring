page {
  min-height: 100%;
  background:
    radial-gradient(circle at 12% 10%, rgba(96, 165, 250, 0.16) 0%, transparent 26%),
    radial-gradient(circle at 86% 18%, rgba(191, 219, 254, 0.22) 0%, transparent 24%),
    radial-gradient(circle at 18% 88%, rgba(125, 211, 252, 0.10) 0%, transparent 22%),
    linear-gradient(135deg, #f8fbff 0%, #f1f6fc 48%, #edf3fa 100%);
  color: #1f2a37;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
}

.page {
  position: relative;
  min-height: 100vh;
  padding: 30rpx 24rpx 42rpx;
  box-sizing: border-box;
}

.page::before {
  content: "";
  position: fixed;
  top: -120rpx;
  right: -90rpx;
  width: 320rpx;
  height: 320rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(96, 165, 250, 0.18) 0%, rgba(96, 165, 250, 0) 72%);
  pointer-events: none;
}

.page::after {
  content: "";
  position: fixed;
  left: -120rpx;
  bottom: 150rpx;
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(147, 197, 253, 0.16) 0%, rgba(147, 197, 253, 0) 72%);
  pointer-events: none;
}

.hero {
  position: relative;
  overflow: hidden;
  margin-bottom: 28rpx;
  padding: 44rpx 34rpx 40rpx;
  border-radius: 38rpx;
  background:
    linear-gradient(135deg, rgba(37, 99, 235, 0.98) 0%, rgba(59, 130, 246, 0.95) 42%, rgba(96, 165, 250, 0.90) 100%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.10), rgba(255, 255, 255, 0));
  border: 1rpx solid rgba(255, 255, 255, 0.24);
  box-shadow:
    0 24rpx 54rpx rgba(37, 99, 235, 0.22),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.24);
  animation: glassFadeUp 0.42s ease both;
}

.hero::before {
  content: "";
  position: absolute;
  top: -90rpx;
  right: -35rpx;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.14);
}

.hero::after {
  content: "";
  position: absolute;
  left: -90rpx;
  bottom: -120rpx;
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
}

.hero-badge,
.hero-title,
.hero-subtitle {
  position: relative;
  z-index: 1;
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 18rpx;
  padding: 10rpx 24rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.22) 0%, rgba(255, 255, 255, 0.14) 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.28);
  color: #f8fbff;
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.20),
    0 8rpx 18rpx rgba(0, 0, 0, 0.05);
  backdrop-filter: blur(14rpx);
  -webkit-backdrop-filter: blur(14rpx);
}

.hero-title {
  color: #ffffff;
  font-size: 50rpx;
  font-weight: 700;
  line-height: 1.24;
  letter-spacing: 1rpx;
  text-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.08);
}

.hero-subtitle {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.92);
  font-size: 26rpx;
  line-height: 1.72;
}

.role-switch {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
  padding: 10rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.80) 0%, rgba(248, 251, 255, 0.72) 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.62);
  box-shadow:
    0 18rpx 36rpx rgba(15, 23, 42, 0.06),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.78);
  backdrop-filter: blur(24rpx);
  -webkit-backdrop-filter: blur(24rpx);
  animation: glassFadeUp 0.46s ease both;
}

.role-pill {
  flex: 1;
  height: 82rpx;
  line-height: 82rpx;
  text-align: center;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #5b6b7e;
  transition: transform 0.18s ease, box-shadow 0.24s ease, background 0.24s ease, color 0.24s ease;
}

.role-pill-active {
  color: #ffffff;
  background:
    linear-gradient(135deg, #2563eb 0%, #3b82f6 45%, #60a5fa 100%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.22), rgba(255, 255, 255, 0));
  box-shadow:
    0 16rpx 30rpx rgba(37, 99, 235, 0.20),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.24);
}

.role-pill:active {
  transform: translateY(1rpx) scale(0.986);
}

.card {
  position: relative;
  margin-bottom: 24rpx;
  padding: 28rpx 26rpx;
  border-radius: 30rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.80) 0%, rgba(248, 251, 255, 0.72) 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.62);
  box-shadow:
    0 18rpx 36rpx rgba(15, 23, 42, 0.06),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.78);
  backdrop-filter: blur(24rpx);
  -webkit-backdrop-filter: blur(24rpx);
  box-sizing: border-box;
  transition: transform 0.18s ease, box-shadow 0.24s ease, border-color 0.24s ease;
  animation: glassFadeUp 0.5s ease both;
}

.section-title {
  position: relative;
  padding-left: 20rpx;
  color: #0f172a;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.4;
}

.section-title::before {
  content: "";
  position: absolute;
  left: 0;
  top: 8rpx;
  width: 8rpx;
  height: 28rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #2563eb 0%, #60a5fa 100%);
  box-shadow: 0 0 14rpx rgba(59, 130, 246, 0.24);
}

.card-desc {
  margin: 18rpx 0 26rpx;
  color: #64748b;
  font-size: 25rpx;
  line-height: 1.76;
}

.primary-btn {
  position: relative;
  overflow: hidden;
  width: 100%;
  height: 94rpx;
  line-height: 94rpx;
  border: none;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #ffffff;
  background:
    linear-gradient(135deg, #2563eb 0%, #3b82f6 45%, #60a5fa 100%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.25), rgba(255, 255, 255, 0));
  box-shadow:
    0 20rpx 34rpx rgba(37, 99, 235, 0.20),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.24);
  transition: transform 0.18s ease, box-shadow 0.24s ease, opacity 0.18s ease, filter 0.24s ease;
}

.primary-btn::after {
  border: none;
}

.primary-btn:active {
  transform: translateY(2rpx) scale(0.985);
  opacity: 0.94;
  filter: saturate(1.03);
}

.sheet {
  position: fixed;
  inset: 0;
  pointer-events: none;
}

.sheet-show {
  pointer-events: auto;
}

.sheet-mask {
  position: absolute;
  inset: 0;
  background: rgba(15, 23, 42, 0.34);
  opacity: 0;
  transition: opacity 0.24s ease;
}

.sheet-show .sheet-mask {
  opacity: 1;
}

.sheet-panel {
  position: absolute;
  left: 18rpx;
  right: 18rpx;
  bottom: 18rpx;
  padding: 30rpx 26rpx 34rpx;
  border-radius: 34rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.92) 0%, rgba(247, 250, 255, 0.84) 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.68);
  box-shadow:
    0 24rpx 54rpx rgba(15, 23, 42, 0.12),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.84);
  transform: translateY(110%);
  transition: transform 0.24s ease;
  backdrop-filter: blur(24rpx);
  -webkit-backdrop-filter: blur(24rpx);
}

.sheet-show .sheet-panel {
  transform: translateY(0);
}

.sheet-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.sheet-title {
  color: #0f172a;
  font-size: 32rpx;
  font-weight: 700;
}

.sheet-close {
  color: #64748b;
  font-size: 24rpx;
  line-height: 1;
}

.field {
  margin-bottom: 20rpx;
}

.field-label {
  margin-bottom: 10rpx;
  color: #64748b;
  font-size: 22rpx;
  line-height: 1.5;
}

.field-input {
  width: 100%;
  height: 92rpx;
  padding: 0 24rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.96) 0%, rgba(246, 249, 255, 0.88) 100%);
  border: 1rpx solid rgba(219, 229, 241, 0.96);
  box-shadow:
    0 10rpx 22rpx rgba(15, 23, 42, 0.05),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.84);
  color: #0f172a;
  font-size: 28rpx;
  box-sizing: border-box;
  transition: transform 0.18s ease, box-shadow 0.22s ease, border-color 0.22s ease, background 0.22s ease;
}

.field-input:focus {
  border-color: rgba(96, 165, 250, 0.92);
  box-shadow:
    0 14rpx 28rpx rgba(37, 99, 235, 0.10),
    0 0 0 4rpx rgba(191, 219, 254, 0.55),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
}

@media (max-width: 360px) {
  .page {
    padding-left: 20rpx;
    padding-right: 20rpx;
  }

  .hero {
    padding: 34rpx 26rpx 30rpx;
  }

  .hero-title {
    font-size: 42rpx;
  }

  .sheet-panel {
    left: 14rpx;
    right: 14rpx;
  }
}
