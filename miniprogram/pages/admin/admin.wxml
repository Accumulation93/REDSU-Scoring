                  <view class="result-name">{{item.name}}</view>
                  <view class="result-meta">{{item.department}}</view>
                </view>
                <view class="result-col result-col-score">{{item.finalScoreDisplay}}</view>
                <view class="result-col result-col-progress">
                  <view class="progress-cell">
                    <view class="progress-top">
                      <text class="progress-count">{{item.progressText}}</text>
                      <text class="progress-percent">{{item.progressPercentText}}</text>
                    </view>
                    <view class="progress-track">
                      <view class="progress-fill" style="{{item.progressFillStyle}}"></view>
                    </view>
                  </view>
                </view>
