          <view class="card-loading-spinner"></view>
        </view>
        <block wx:else>
          <view class="list-desc completion-intro">这里展示各部门评分人的完成情况，进度按已完成全部评分任务的人数统计。</view>
          <view class="stats-grid stats-grid-completion">
            <view class="stat-card stat-card-clickable {{selectedCompletionDepartment === item.groupName ? 'stat-card-selected' : ''}}" wx:for="{{scoreResultsView.completionBoards.departments}}" wx:key="groupName" data-group-name="{{item.groupName}}" bindtap="toggleDepartmentScorers">
              <view class="stat-card-top">
                <view class="stat-group-name">{{item.groupName}}</view>
                <view class="stat-value stat-value-large">{{item.progressPercentText}}</view>
              </view>
              <view class="completion-progress">
                <view class="progress-top">
                  <text class="progress-count">{{item.completionText}}</text>
                </view>
                <view class="progress-track">
                  <view class="progress-fill" style="{{item.progressFillStyle}}"></view>
                </view>
              </view>
            </view>
          </view>
          <view class="empty-inline" wx:if="{{!scoreResultsView.completionBoards.departments.length}}">当前筛选条件下暂无完成率数据。</view>
        </block>
      </view>

      <view class="list-card" wx:if="{{resultFilters.viewMode === 'completion' && selectedCompletionDepartment}}">
        <view class="popup-header result-drill-header">
          <view class="list-title">{{selectedCompletionDepartment}}评分人完成情况</view>
          <text class="popup-close" bindtap="closeDepartmentScorers">收起</text>
        </view>
        <view class="card-loading-overlay" wx:if="{{departmentScorerLoading}}">
          <view class="card-loading-spinner"></view>
        </view>
        <block wx:else>
          <view class="result-table">
            <view class="result-table-head">
              <view class="result-col result-col-popup-name">评分人</view>
              <view class="result-col result-col-popup-detail">具体信息</view>
              <view class="result-col result-col-popup-progress">已评/应评</view>
              <view class="result-col result-col-popup-status">状态</view>
            </view>
            <view class="result-table-row result-table-row-clickable" wx:for="{{departmentScorerRows}}" wx:key="scorerKey" data-scorer-key="{{item.scorerKey}}" bindtap="openScorerTargetPopup">
              <view class="result-col result-col-popup-name">
                <view class="result-name">{{item.scorerName}}</view>
                <view class="result-meta">{{item.scorerStudentId}}</view>
              </view>
              <view class="result-col result-col-popup-detail">
                <view class="result-meta result-meta-strong">{{item.detailText}}</view>
              </view>
              <view class="result-col result-col-popup-progress">
                <view class="progress-cell">
                  <view class="progress-top">
                    <text class="progress-count">{{item.completionText}}</text>
                    <text class="progress-percent">{{item.progressPercentText}}</text>
                  </view>
                  <view class="progress-track">
                    <view class="progress-fill" style="{{item.progressFillStyle}}"></view>
                  </view>
                </view>
              </view>
              <view class="result-col result-col-popup-status">
                <view class="status-chip {{item.statusClass}}">{{item.statusText}}</view>
              </view>
            </view>
          </view>
          <view class="empty-inline" wx:if="{{!departmentScorerRows.length}}">当前条件下暂无评分人数据。</view>
        </block>
      </view>

    </view>

    <view class="section" wx:if="{{activeTab === 'profile'}}">
      <view class="edit-box">
        <view class="template-section-head">
          <view class="list-title">模板配置</view>
          <view class="template-section-tip">基础敏感字段仍由后台统一维护，模板只负责扩展资料采集。</view>
        </view>
        <view class="field">
          <view class="field-label">填写说明</view>
          <textarea class="field-textarea" auto-height maxlength="-1" data-field="description" bindinput="onHrProfileTemplateInput" value="{{hrProfileTemplateForm.description}}" placeholder="告诉普通用户这份人事信息用于什么、如何填写" />
        </view>
        <view class="field">
          <view class="field-label">修改模式</view>
          <picker range="{{profileEditModeOptions}}" range-key="label" bindchange="onHrProfileEditModeChange">
            <view class="picker-value">{{hrProfileTemplateForm.editModeLabel}}</view>
          </picker>
        </view>

        <view class="list-card nested-card">
          <view class="list-title">扩展字段</view>
          <scroll-view
            class="inner-scroll large-scroll"
            scroll-y
            lower-threshold="80"
            bindscrolltolower="loadMoreScoreResults"
          >
            <view class="question-card" wx:for="{{hrProfileTemplateForm.fields}}" wx:key="id">
              <view class="question-title">字段 {{index + 1}}</view>
              <view class="field">
                <view class="field-label">字段名称</view>
                <input class="field-input" data-index="{{index}}" data-field="label" bindinput="onHrProfileFieldInput" value="{{item.label}}" placeholder="例如：宿舍号 / 籍贯 / 年级" />
              </view>
              <view class="field">
                <view class="field-label">字段类型</view>
                <picker range="{{profileFieldTypeOptions}}" range-key="label" bindchange="onHrProfileFieldTypeChange" data-index="{{index}}">
                  <view class="picker-value">{{item.typeLabel}}</view>
                </picker>
              </view>
              <view class="field">
                <view class="field-label">是否必填</view>
                <switch checked="{{item.required}}" color="#2563eb" data-index="{{index}}" bindchange="onHrProfileFieldRequiredChange" />
              </view>
              <view class="field field-row" wx:if="{{item.type === 'text'}}">
                <view class="field field-half">
                  <view class="field-label">最短长度</view>
                  <input class="field-input" data-index="{{index}}" data-field="minLength" bindinput="onHrProfileFieldInput" value="{{item.minLength}}" placeholder="可留空" />
                </view>
                <view class="field field-half">
                  <view class="field-label">最大长度</view>
                  <input class="field-input" data-index="{{index}}" data-field="maxLength" bindinput="onHrProfileFieldInput" value="{{item.maxLength}}" placeholder="可留空" />
                </view>
              </view>
              <view wx:if="{{item.type === 'number'}}">
                <view class="field">
                  <view class="field-label">数字限制方式</view>
                  <picker range="{{numberRuleOptions}}" range-key="label" bindchange="onHrProfileNumberRuleChange" data-index="{{index}}">
                    <view class="picker-value">{{item.numberRuleLabel}}</view>
                  </picker>
                </view>
                <view class="field">
                  <view class="field-label">允许小数</view>
                  <switch checked="{{item.allowDecimal}}" color="#2563eb" data-index="{{index}}" bindchange="onHrProfileFieldAllowDecimalChange" />
                </view>
                <view class="field field-row" wx:if="{{item.numberRule === 'value_range'}}">
                  <view class="field field-half">
                    <view class="field-label">最小值</view>
                    <input class="field-input" data-index="{{index}}" data-field="minValue" bindinput="onHrProfileFieldInput" value="{{item.minValue}}" placeholder="可留空" />
                  </view>
                  <view class="field field-half">
                    <view class="field-label">最大值</view>
                    <input class="field-input" data-index="{{index}}" data-field="maxValue" bindinput="onHrProfileFieldInput" value="{{item.maxValue}}" placeholder="可留空" />
                  </view>
                </view>
                <view class="field field-row" wx:if="{{item.numberRule === 'length_range'}}">
                  <view class="field field-half">
                    <view class="field-label">最短长度</view>
                    <input class="field-input" data-index="{{index}}" data-field="minDigits" bindinput="onHrProfileFieldInput" value="{{item.minDigits}}" placeholder="可留空" />
                  </view>
                  <view class="field field-half">
                    <view class="field-label">最长长度</view>
                    <input class="field-input" data-index="{{index}}" data-field="maxDigits" bindinput="onHrProfileFieldInput" value="{{item.maxDigits}}" placeholder="可留空" />
                  </view>
                </view>
              </view>
              <view class="field" wx:if="{{item.type === 'sequence'}}">
                <view class="field-label">序列选项</view>
                <textarea class="field-textarea question-textarea" auto-height maxlength="-1" data-index="{{index}}" data-field="optionsText" bindinput="onHrProfileFieldInput" value="{{item.optionsText}}" placeholder="每行一个选项，例如：&#10;本科&#10;硕士&#10;博士" />
              </view>
              <view class="button-row compact-row">
                <button class="secondary-btn" data-index="{{index}}" bindtap="removeHrProfileField">删除字段</button>
              </view>
            </view>
          </scroll-view>
        </view>

        <view class="button-row">
          <button class="secondary-btn" bindtap="addHrProfileField">新增字段</button>
          <button class="primary-btn template-save-btn" loading="{{loadingMap.saveProfileTemplate}}" bindtap="saveHrProfileTemplate">保存模板配置</button>
        </view>
      </view>

      <view class="list-card">
        <view class="template-section-head">
          <view class="list-title">用户资料与审核</view>
          <view class="template-section-tip">待审核资料会在通过后正式生效，驳回后用户可重新提交。</view>
        </view>
        <view class="field field-row">
          <view class="field field-half">
            <view class="field-label">部门</view>
            <picker range="{{hrProfileFilterOptions.departments}}" bindchange="onHrProfileFilterChange" data-field="departments">
              <view class="picker-value">{{hrProfileFilters.department}}</view>
            </picker>
          </view>
          <view class="field field-half">
            <view class="field-label">身份</view>
            <picker range="{{hrProfileFilterOptions.identities}}" bindchange="onHrProfileFilterChange" data-field="identities">
              <view class="picker-value">{{hrProfileFilters.identity}}</view>
            </picker>
          </view>
        </view>
        <view class="field field-row">
          <view class="field field-half">
            <view class="field-label">工作分工（职能组）</view>
            <picker range="{{hrProfileFilterOptions.workGroups}}" bindchange="onHrProfileFilterChange" data-field="workGroups">
              <view class="picker-value">{{hrProfileFilters.workGroup}}</view>
            </picker>
          </view>
          <view class="field field-half">
            <view class="field-label">状态</view>
            <picker range="{{hrProfileFilterOptions.statuses}}" bindchange="onHrProfileFilterChange" data-field="statuses">
              <view class="picker-value">{{hrProfileFilters.status}}</view>
            </picker>
          </view>
        </view>
        <view class="field">
          <view class="field-label">姓名</view>
          <input class="field-input" bindinput="onHrProfileKeywordInput" value="{{hrProfileFilters.keyword}}" placeholder="输入姓名或学号筛选" />
        </view>
        <view class="button-row compact-row">
          <button class="secondary-btn" bindtap="resetHrProfileFilters">重置筛选</button>
        </view>
        <scroll-view
          class="inner-scroll large-scroll"
          scroll-y
          lower-threshold="80"
          bindscrolltolower="loadMoreScoreResults"
        >
          <view class="list-item list-item-stacked" wx:for="{{hrProfileRows}}" wx:key="id">
            <view class="list-main">
              <view class="list-name">{{item.name}} - {{item.identity}}</view>
              <view class="list-desc">{{item.studentId}} - {{item.department}} {{item.workGroup}}</view>
              <view class="list-desc">当前资料：{{item.currentSummary}}</view>
              <view class="list-desc" wx:if="{{item.pendingSummary}}">待审核：{{item.pendingSummary}}</view>
              <view class="list-desc" wx:if="{{item.rejectionReason}}">驳回原因：{{item.rejectionReason}}</view>
              <view class="chip-row">
                <view class="status-chip current-chip">{{item.auditStatusText}}</view>
              </view>
              <view class="inline-actions list-actions-below" wx:if="{{item.hasPending}}">
                <text class="link" data-student-id="{{item.studentId}}" bindtap="approveHrProfileChange">通过</text>
                <text class="link danger" data-student-id="{{item.studentId}}" bindtap="rejectHrProfileChange">驳回</text>
              </view>
            </view>
          </view>
          <view class="empty-inline" wx:if="{{!hrProfileRows.length}}">当前筛选条件下暂无记录</view>
        </scroll-view>
      </view>
    </view>

    <view class="section" wx:if="{{activeTab === 'hr'}}">
      <view class="section-title">人事成员</view>
      <view class="button-row compact-row">
