<view class="page">
  <view class="hero hero-admin" wx:if="{{hasPermission}}">
    <view class="hero-badge">管理端</view>
    <view class="hero-title">评分管理工作台</view>
    <view class="hero-subtitle hero-admin-subtitle">{{user.name}} - {{isRootAdmin ? '至高权限管理员' : (isSuperAdmin ? '超级管理员' : '普通管理员')}}</view>
  </view>

  <view class="empty-card" wx:if="{{!hasPermission}}">
    <view class="empty-title">当前没有管理权限</view>
    <view class="empty-desc">请先使用管理员身份登录。</view>
  </view>

  <view wx:if="{{hasPermission}}">
    <view class="tabs">
      <view class="tab {{activeTab === 'activities' ? 'tab-active' : ''}}" data-tab="activities" bindtap="switchTab">评分活动</view>
      <view class="tab {{activeTab === 'templates' ? 'tab-active' : ''}}" data-tab="templates" bindtap="switchTab">评分问题</view>
      <view class="tab {{activeTab === 'rules' ? 'tab-active' : ''}}" data-tab="rules" bindtap="switchTab">评分人类别</view>
      <view class="tab {{activeTab === 'results' ? 'tab-active' : ''}}" data-tab="results" bindtap="switchTab">结果查看</view>
      <view class="tab {{activeTab === 'profile' ? 'tab-active' : ''}}" data-tab="profile" bindtap="switchTab">信息模板</view>
      <view class="tab {{activeTab === 'hr' ? 'tab-active' : ''}}" data-tab="hr" bindtap="switchTab">人事成员</view>
      <view class="tab {{activeTab === 'departments' ? 'tab-active' : ''}}" data-tab="departments" bindtap="switchTab">部门维护</view>
      <view class="tab {{activeTab === 'workGroups' ? 'tab-active' : ''}}" data-tab="workGroups" bindtap="switchTab">工作分工</view>
      <view class="tab {{activeTab === 'identities' ? 'tab-active' : ''}}" data-tab="identities" bindtap="switchTab">身份类别</view>
      <view class="tab {{activeTab === 'admins' ? 'tab-active' : ''}}" data-tab="admins" bindtap="switchTab">管理员</view>
      <view class="tab {{activeTab === 'settings' ? 'tab-active' : ''}}" data-tab="settings" bindtap="switchTab">基础配置</view>
    </view>

    <view class="section" wx:if="{{activeTab === 'activities'}}">
      <view class="section-title">评分活动</view>
      <view class="edit-box">
        <view class="list-title">{{activityForm.id ? '编辑活动' : '新建活动'}}</view>
        <view class="field">
          <view class="field-label">活动名称</view>
          <input class="field-input" data-field="name" bindinput="onActivityFieldInput" value="{{activityForm.name}}" placeholder="请输入活动名称" />
        </view>
        <view class="field">
          <view class="field-label">活动说明</view>
          <textarea class="field-textarea" auto-height maxlength="-1" data-field="description" bindinput="onActivityFieldInput" value="{{activityForm.description}}" placeholder="请输入活动说明" />
        </view>
        <view class="field field-row">
          <view class="field field-half">
            <view class="field-label">开始日期</view>
            <input class="field-input" data-field="startDate" bindinput="onActivityFieldInput" value="{{activityForm.startDate}}" placeholder="例如：2026-04-24" />
          </view>
          <view class="field field-half">
            <view class="field-label">结束日期</view>
            <input class="field-input" data-field="endDate" bindinput="onActivityFieldInput" value="{{activityForm.endDate}}" placeholder="例如：2026-05-01" />
          </view>
        </view>
        <view class="button-row">
          <button class="primary-btn" loading="{{loadingMap.saveActivity}}" bindtap="saveActivity">保存活动</button>
          <button class="secondary-btn" bindtap="startCreateActivity">新建活动</button>
        </view>
      </view>

      <view class="list-card">
        <view class="list-title">活动列表</view>
        <scroll-view class="inner-scroll medium-scroll" scroll-y>
          <view class="list-item list-item-stacked" wx:for="{{activityList}}" wx:key="id">
            <view class="list-main">
              <view class="list-name">{{item.name}}</view>
              <view class="chip-row">
                <view class="status-chip current-chip" wx:if="{{item.isCurrent}}">当前活动</view>
              </view>
              <view class="list-desc">{{item.description}}</view>
              <view class="list-desc">{{item.startDate}} {{item.endDate}}</view>
              <view class="inline-actions list-actions-below">
                <text class="link" data-id="{{item.id}}" bindtap="setCurrentActivity">设为当前</text>
                <text class="link" data-index="{{index}}" bindtap="editActivity">编辑</text>
                <text class="link danger" data-id="{{item.id}}" bindtap="deleteActivity">删除</text>
              </view>
            </view>
          </view>
        </scroll-view>
      </view>
    </view>

    <view class="section" wx:if="{{activeTab === 'templates'}}">
      <view class="section-title">评分问题</view>
      <view class="edit-box">
        <view class="list-title">{{templateForm.id ? '编辑评分问题' : '新建评分问题'}}</view>
        <view class="field">
          <view class="field-label">评分问题名称</view>
          <input class="field-input" data-field="name" bindinput="onTemplateFieldInput" value="{{templateForm.name}}" placeholder="请输入评分问题名称" />
        </view>
        <view class="field">
          <view class="field-label">评分问题说明</view>
          <textarea class="field-textarea" auto-height maxlength="-1" data-field="description" bindinput="onTemplateFieldInput" value="{{templateForm.description}}" placeholder="请输入评分问题说明" />
        </view>

        <view class="list-card nested-card">
          <view class="list-title">问题条目</view>
          <scroll-view
            class="inner-scroll large-scroll"
            scroll-y
            lower-threshold="80"
            bindscrolltolower="loadMoreScoreResults"
          >
            <view class="question-card" wx:for="{{templateForm.questions}}" wx:key="index">
              <view class="question-title">问题 {{index + 1}}</view>
              <view class="field">
                <view class="field-label">问题内容</view>
                <input class="field-input" data-index="{{index}}" data-field="question" bindinput="onTemplateQuestionInput" value="{{item.question}}" placeholder="请输入问题内容" />
              </view>
              <view class="field">
                <view class="field-label">分值说明</view>
                <textarea class="field-textarea question-textarea" auto-height maxlength="-1" data-index="{{index}}" data-field="scoreLabel" bindinput="onTemplateQuestionInput" value="{{item.scoreLabel}}" placeholder="请输入分值说明" />
              </view>
              <view class="field field-row">
                <view class="field field-half">
                  <view class="field-label">最低分</view>
                  <input class="field-input" data-index="{{index}}" data-field="minValue" bindinput="onTemplateQuestionInput" value="{{item.minValue}}" placeholder="0" />
                </view>
                <view class="field field-half">
                  <view class="field-label">起评分</view>
                  <input class="field-input" data-index="{{index}}" data-field="startValue" bindinput="onTemplateQuestionInput" value="{{item.startValue}}" placeholder="0" />
                </view>
              </view>
              <view class="field field-row">
                <view class="field field-half">
                  <view class="field-label">最高分</view>
                  <input class="field-input" data-index="{{index}}" data-field="maxValue" bindinput="onTemplateQuestionInput" value="{{item.maxValue}}" placeholder="10" />
                </view>
                <view class="field field-half">
                  <view class="field-label">步进值</view>
                  <input class="field-input" data-index="{{index}}" data-field="stepValue" bindinput="onTemplateQuestionInput" value="{{item.stepValue}}" placeholder="0.5" />
                </view>
              </view>
              <view class="button-row compact-row">
                <button class="secondary-btn" data-index="{{index}}" bindtap="removeTemplateQuestion">删除问题</button>
              </view>
            </view>
          </scroll-view>
        </view>

        <view class="button-row">
          <button class="secondary-btn" bindtap="addTemplateQuestion">新增问题</button>
          <button class="primary-btn" loading="{{loadingMap.saveTemplate}}" bindtap="saveTemplate">保存评分问题</button>
          <button class="secondary-btn" bindtap="startCreateTemplate">重置表单</button>
        </view>
      </view>

      <view class="list-card">
        <view class="list-title">评分问题列表</view>
        <scroll-view class="inner-scroll medium-scroll" scroll-y>
          <view class="list-item list-item-stacked" wx:for="{{templateList}}" wx:key="id">
            <view class="list-main">
              <view class="list-name">{{item.name}}</view>
              <view class="list-desc">{{item.description}}</view>
              <view class="list-desc">问题数：{{item.questionCount}}</view>
              <view class="inline-actions list-actions-below">
                <text class="link" data-id="{{item.id}}" bindtap="duplicateTemplate">复制</text>
                <text class="link" data-index="{{index}}" bindtap="editTemplate">编辑</text>
                <text class="link danger" data-id="{{item.id}}" bindtap="deleteTemplate">删除</text>
              </view>
            </view>
          </view>
        </scroll-view>
      </view>
    </view>

    <view class="section" wx:if="{{activeTab === 'rules'}}">
      <view class="rule-panel">
        <view class="rule-panel-head">
          <view class="rule-panel-title">评分人信息</view>
          <view class="rule-panel-subtitle">选择或新建评分人类别后，可在下方配置被评分人规则</view>
        </view>
        <view class="field">
          <view class="field-label">评分人所属部门</view>
          <picker range="{{departmentList}}" range-key="name" bindchange="onRuleScorerDepartmentChange"><view class="picker-value">{{ruleForm.scorerDepartment || '请选择部门'}}</view></picker>
        </view>
        <view class="field">
          <view class="field-label">评分人身份</view>
          <picker range="{{identityList}}" range-key="name" bindchange="onRuleScorerIdentityChange"><view class="picker-value">{{ruleForm.scorerIdentity || '请选择身份'}}</view></picker>
        </view>
        <view class="button-row">
          <button class="primary-btn" loading="{{loadingMap.saveRule}}" bindtap="saveRuleCategory">保存类别</button>
          <button class="secondary-btn" bindtap="startCreateRuleCategory">新增类别</button>
          <button class="secondary-btn" disabled="{{loadingMap.batchSaveRules}}" bindtap="applyClausesToSelectedRules">批量应用到已选类别</button>
          <button class="secondary-btn" disabled="{{loadingMap.generateRules}}" bindtap="generateRuleCategoriesFinal">生成默认类别</button>
        </view>
      </view>

      <view class="rule-panel">
        <view class="rule-panel-head rule-panel-head-row">
          <view>
            <view class="rule-panel-title">当前被评分人规则</view>
            <view class="rule-panel-subtitle">编辑评分人类别后，可在这里查看每条规则的范围、模板和权重</view>
          </view>
          <button class="secondary-btn mini-action-btn" bindtap="openNewRuleClauseEditor">新建被评分人规则</button>
        </view>
        <view class="rule-empty" wx:if="{{!ruleForm.clauses.length}}">暂无被评分人规则</view>
        <view class="rule-clause-card" wx:for="{{ruleForm.clauses}}" wx:key="index">
          <view class="rule-clause-main">
            <view class="rule-clause-title">{{item.targetIdentity || '不限制被评分人身份'}}</view>
            <view class="rule-tag-row">
              <text class="rule-tag tag-scope">{{item.scopeLabel || item.scopeType}}</text>
              <text class="rule-tag tag-target">{{item.targetIdentity || '不限身份'}}</text>
              <text class="rule-tag {{item.requireAllComplete ? 'tag-required' : 'tag-free'}}">{{item.requireAllComplete ? '要求全评' : '不要求全评'}}</text>
            </view>
          </view>
          <view class="rule-template-list" wx:if="{{item.templateConfigs.length}}">
            <view class="rule-template-row" wx:for="{{item.templateConfigs}}" wx:for-item="template" wx:for-index="templateIndex" wx:key="templateId">
              <view class="rule-template-name">{{template.templateName || '未命名评分问题'}}</view>
              <view class="rule-template-tags">
                <text class="rule-tag tag-weight">权重 {{template.weight}}</text>
                <text class="rule-tag tag-order">顺序 {{template.sortOrder}}</text>
              </view>
            </view>
          </view>
          <view class="rule-empty small-empty" wx:else>未配置评分问题</view>
          <view class="pill-actions rule-card-actions">
            <text class="pill-link" data-index="{{index}}" bindtap="editRuleClause">编辑</text>
            <text class="pill-close" data-index="{{index}}" bindtap="removeRuleClause">删除</text>
          </view>
        </view>
      </view>

      <view class="rule-panel" wx:if="{{ruleForm.isRuleClauseEditorVisible}}">
        <view class="rule-panel-head rule-panel-head-row">
          <view>
            <view class="rule-panel-title">被评分人规则编辑</view>
            <view class="rule-panel-subtitle">{{ruleForm.clauseEditingIndex >= 0 ? '正在编辑当前被评分人规则' : '添加一条新的被评分人规则'}}</view>
          </view>
          <button class="secondary-btn mini-action-btn" bindtap="openTemplateConfigEditor">添加评分问题</button>
        </view>
        <view class="field">
          <view class="field-label">被评分范围</view>
          <picker range="{{scopeOptions}}" range-key="label" bindchange="onClauseScopeChange">
            <view class="picker-value">{{ruleForm.clauseScopeLabel}}</view>
          </picker>
        </view>
        <view class="field">
          <view class="field-label">被评分人身份</view>
          <picker range="{{identityList}}" range-key="name" bindchange="onRuleTargetIdentityChange"><view class="picker-value">{{ruleForm.clauseTargetIdentity || '不限制身份'}}</view></picker>
        </view>
        <view class="rule-switch-row">
          <view>
            <view class="field-label">是否要求全评</view>
            <view class="rule-panel-subtitle">开启后，评分人完成本规则下全部评分后才计入核算</view>
          </view>
          <switch checked="{{ruleForm.clauseRequireAllComplete}}" color="#2563eb" bindchange="onClauseRequireAllCompleteChange" />
        </view>

        <view class="rule-config-list" wx:if="{{ruleForm.clauseTemplateConfigs.length}}">
          <view class="list-title">评分问题及顺序</view>
          <view
            class="template-config-card {{draggingClauseTemplateIndex === index ? 'dragging-item' : ''}}"
            wx:for="{{ruleForm.clauseTemplateConfigs}}"
            wx:key="index"
            data-index="{{index}}"
            bindlongpress="startClauseTemplateDrag"
            catchtouchmove="onClauseTemplateDragMove"
            catchtouchend="endClauseTemplateDrag"
            catchtouchcancel="onClauseTemplateDragCancel"
          >
            <view class="template-config-name">{{item.templateName || '未命名评分问题'}}</view>
            <view class="template-config-meta">
              <text class="rule-tag tag-weight">权重 {{item.weight}}</text>
              <text class="rule-tag tag-order">顺序 {{item.sortOrder}}</text>
            </view>
            <view class="pill-actions template-config-actions">
              <text class="pill-link" data-index="{{index}}" bindtap="editClauseTemplateConfig">编辑</text>
              <text class="pill-close" data-index="{{index}}" bindtap="removeClauseTemplateConfig">删除</text>
            </view>
          </view>
        </view>

        <view class="button-row compact-row">
          <button class="secondary-btn" bindtap="addRuleClause">{{ruleForm.clauseEditingIndex >= 0 ? '保存被评分人规则' : '加入当前被评分人规则'}}</button>
          <button class="secondary-btn" bindtap="cancelRuleClauseEdit">取消被评分人规则编辑</button>
        </view>
      </view>

      <view class="rule-panel" wx:if="{{ruleForm.isTemplateConfigEditorVisible}}">
        <view class="rule-panel-head">
          <view class="rule-panel-title">评分问题编辑</view>
          <view class="rule-panel-subtitle">{{ruleForm.clauseTemplateConfigEditingIndex >= 0 ? '正在编辑评分问题配置' : '为当前被评分人规则添加评分问题'}}</view>
        </view>
        <view class="field">
          <view class="field-label">评分问题</view>
          <picker range="{{templateList}}" range-key="name" bindchange="onRuleTemplateChange">
            <view class="picker-value">{{ruleForm.clauseTemplateName || '请选择评分问题'}}</view>
          </picker>
        </view>
        <view class="field field-row">
          <view class="field field-half">
            <view class="field-label">权重</view>
            <input class="field-input" data-field="clauseTemplateWeight" bindinput="onRuleFieldInput" value="{{ruleForm.clauseTemplateWeight}}" placeholder="1" />
          </view>
        </view>
        <view class="button-row compact-row">
          <button class="secondary-btn" bindtap="addClauseTemplateConfig">保存评分问题配置</button>
          <button class="secondary-btn" bindtap="cancelClauseTemplateConfigEdit">取消评分问题编辑</button>
        </view>
      </view>

      <view class="list-card rule-list-card">
        <view class="rule-list-toolbar">
          <view>
            <view class="list-title">评分人类别列表</view>
            <view class="rule-panel-subtitle">筛选只影响当前显示，已选择的类别会保持选中</view>
          </view>
          <view class="rule-list-count">{{ruleListView.length}} / {{ruleList.length}}</view>
        </view>
        <view class="rule-filter-row">
          <view class="rule-filter-field">
            <view class="field-label">部门筛选</view>
            <picker range="{{ruleFilterOptions.departments}}" bindchange="onRuleFilterChange" data-field="department">
              <view class="picker-value compact-picker-value">{{ruleFilters.department}}</view>
            </picker>
          </view>
          <view class="rule-filter-field">
            <view class="field-label">身份筛选</view>
            <picker range="{{ruleFilterOptions.identities}}" bindchange="onRuleFilterChange" data-field="identity">
              <view class="picker-value compact-picker-value">{{ruleFilters.identity}}</view>
            </picker>
          </view>
        </view>
        <view class="button-row compact-row">
          <button class="secondary-btn" bindtap="toggleSelectAllRules">{{visibleRuleAllSelected ? '取消当前全选' : '全选当前列表'}}</button>
          <button class="secondary-btn" bindtap="reverseSelectVisibleRules">反选当前列表</button>
          <button class="secondary-btn" bindtap="resetRuleFilters">清除筛选</button>
        </view>
        <scroll-view class="inner-scroll medium-scroll" scroll-y>
          <view class="list-item rule-list-item" wx:for="{{ruleListView}}" wx:key="id">
            <view class="list-main">
              <view class="rule-list-action-row">
                <view class="select-chip {{selectedRuleIdMap[item.id] ? 'select-chip-active' : ''}}" data-id="{{item.id}}" catchtap="toggleRuleSelection">
                  {{selectedRuleIdMap[item.id] ? '已选' : '选择'}}
                </view>
                <view class="inline-actions rule-list-inline-actions">
                  <text class="link" data-id="{{item.id}}" bindtap="editRule">编辑</text>
                  <text class="link danger" data-id="{{item.id}}" bindtap="deleteRule">删除</text>
                </view>
              </view>
              <view class="rule-list-info">
                <view class="rule-list-main-line">
                  <text class="rule-info-text">{{item.scorerDepartment || '未设置部门'}} / {{item.scorerIdentity || '未设置身份'}}</text>
                </view>
                <view class="rule-list-meta">
                  <text class="rule-tag tag-scope">{{item.ruleCount || 0}} 条被评分人规则</text>
                </view>
              </view>
            </view>
          </view>
          <view class="empty-inline" wx:if="{{!ruleListView.length}}">当前筛选下暂无评分人类别</view>
        </scroll-view>
      </view>
    </view>

    <view class="section" wx:if="{{activeTab === 'results'}}">
      <view class="section-title">评分结果</view>
      <view class="list-card">
        <view class="list-title">当前评分活动</view>
        <view class="result-current">{{currentActivityName || '暂无当前评分活动'}}</view>
      </view>

      <view class="stats-panel">
        <view class="stats-grid stats-grid-summary">
          <view class="stat-card">
            <view class="stat-label">成员总数</view>
            <view class="stat-value">{{scoreResultsRaw.stats.totalMembers || 0}}</view>
          </view>
          <view class="stat-card">
            <view class="stat-label">已有得分成员</view>
            <view class="stat-value">{{scoreResultsRaw.stats.scoredMembers || 0}}</view>
          </view>
          <view class="stat-card">
            <view class="stat-label">评分记录数</view>
            <view class="stat-value">{{scoreResultsRaw.stats.recordCount || 0}}</view>
          </view>
          <view class="stat-card">
            <view class="stat-label">已完成评分人数</view>
            <view class="stat-value">{{scoreResultsRaw.stats.completedMembers || 0}}</view>
          </view>
        </view>
      </view>

      <view class="edit-box">
        <view class="list-title">筛选条件</view>
        <view class="field field-row">
          <view class="field field-half">
            <view class="field-label">所属部门</view>
            <picker range="{{resultFilterOptions.departments}}" bindchange="onResultFilterChange" data-field="department">
              <view class="picker-value">{{resultFilters.department}}</view>
            </picker>
          </view>
          <view class="field field-half">
            <view class="field-label">身份</view>
            <picker range="{{resultFilterOptions.identities}}" bindchange="onResultFilterChange" data-field="identity">
              <view class="picker-value">{{resultFilters.identity}}</view>
            </picker>
          </view>
        </view>
        <view class="field field-row">
          <view class="field field-half">
            <view class="field-label">工作分工（职能组）</view>
            <picker range="{{resultFilterOptions.workGroups}}" bindchange="onResultFilterChange" data-field="workGroup">
              <view class="picker-value">{{resultFilters.workGroup}}</view>
            </picker>
          </view>
          <view class="field field-half">
            <view class="field-label">结果视图</view>
            <picker range="{{resultViewOptions}}" range-key="label" bindchange="onResultFilterChange" data-field="viewMode">
              <view class="picker-value">{{resultViewLabel}}</view>
            </picker>
          </view>
        </view>
        <view class="field">
          <view class="field-label">排序方式</view>
          <picker range="{{resultSortOptions}}" range-key="label" bindchange="onResultFilterChange" data-field="sortMode">
            <view class="picker-value">{{resultSortLabel}}</view>
          </picker>
        </view>
        <view class="button-row compact-row">
          <button class="secondary-btn" loading="{{loadingMap.results}}" bindtap="reloadScoreResults">重算并刷新</button>

        </view>
        <view class="filter-loading-bar" wx:if="{{loadingMap.results}}">
          <view class="filter-loading-spinner"></view>
          <text class="filter-loading-text">正在加载评分结果...</text>
        </view>
      </view>

      <view class="edit-box">
        <view class="list-title">总分速览导出</view>
        <view class="button-row">
          <button class="secondary-btn" loading="{{loadingMap.export_overview_csv}}" data-report="overview" data-format="csv" bindtap="exportScoreResults">总分速览 CSV</button>
          <button class="secondary-btn" loading="{{loadingMap.export_overview_excel}}" data-report="overview" data-format="excel" bindtap="exportScoreResults">总分速览 Excel</button>
        </view>
      </view>

      <view class="edit-box">
        <view class="list-title">评分明细导出</view>
        <view class="button-row">
          <button class="secondary-btn" loading="{{loadingMap.export_detail_csv}}" data-report="detail" data-format="csv" bindtap="exportScoreResults">评分明细 CSV</button>
          <button class="secondary-btn" loading="{{loadingMap.export_detail_excel}}" data-report="detail" data-format="excel" bindtap="exportScoreResults">评分明细 Excel</button>
        </view>
      </view>

      <view class="edit-box">
        <view class="list-title">完成率导出</view>
        <view class="button-row">
