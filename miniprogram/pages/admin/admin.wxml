            wx:key="scorerKey"
            data-record-id="{{item.recordId}}"
            bindtap="openScoreRecordDetail"
          >
            <view class="list-main">
              <view class="scorer-card-title">
                <view class="list-name scorer-name">{{item.scorerName}}</view>
                <view class="status-chip scorer-inline-status {{item.statusClass}}">{{item.statusText}}</view>
              </view>
              <view class="scorer-meta-lines">
                <view class="list-desc">部门：{{item.departmentText}}</view>
                <view class="list-desc">身份：{{item.identityText}}</view>
                <view class="list-desc" wx:if="{{item.workGroupText}}">工作分工（职能组）：{{item.workGroupText}}</view>
              </view>
              <view class="list-desc submitted-text" wx:if="{{item.submittedAt}}">{{item.submittedAt}}</view>
            </view>
          </view>
