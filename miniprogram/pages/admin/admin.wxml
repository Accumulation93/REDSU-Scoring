        </view>
        <view class="field">
          <view class="field-label">部门描述</view>
          <textarea class="field-textarea" auto-height maxlength="-1" data-field="description" bindinput="onDepartmentFieldInput" value="{{departmentForm.description}}" placeholder="请输入部门描述" />
        </view>
        <view class="button-row">
          <button class="primary-btn" loading="{{loadingMap.saveDepartment}}" bindtap="saveDepartment">保存部门</button>
          <button class="secondary-btn" bindtap="startCreateDepartment">新增部门</button>
        </view>
      </view>

      <view class="list-card">
        <view class="list-title">部门列表</view>
        <scroll-view class="inner-scroll medium-scroll" scroll-y>
          <view class="list-item list-item-stacked" wx:for="{{departmentList}}" wx:key="id">
            <view class="list-main">
              <view class="list-name">{{item.name}}</view>
              <view class="list-desc">{{item.description}}</view>
              <view class="inline-actions list-actions-below">
                <text class="link" data-index="{{index}}" bindtap="editDepartment">编辑</text>
                <text class="link danger" data-id="{{item.id}}" bindtap="deleteDepartment">删除</text>
              </view>
            </view>
          </view>
        </scroll-view>
        <view class="empty-inline" wx:if="{{!departmentList.length}}">当前没有部门数据。</view>
      </view>
    </view>

    <view class="section" wx:if="{{activeTab === 'workGroups'}}">
      <view class="section-title">工作分工（职能组）维护</view>
      <view class="edit-box">
        <view class="list-title">{{workGroupForm.id ? '编辑工作分工' : '新增工作分工'}}</view>
        <view class="field">
          <view class="field-label">工作分工名称</view>
          <input class="field-input" data-field="name" bindinput="onWorkGroupFieldInput" value="{{workGroupForm.name}}" placeholder="请输入工作分工名称" />
        </view>
        <view class="field">
          <view class="field-label">所属部门</view>
          <picker range="{{departmentList}}" range-key="name" bindchange="onWorkGroupDepartmentChange">
            <view class="picker-value">{{workGroupForm.departmentName || '请选择部门'}}</view>
          </picker>
        </view>
        <view class="field">
          <view class="field-label">工作分工描述</view>
          <textarea class="field-textarea" auto-height maxlength="-1" data-field="description" bindinput="onWorkGroupFieldInput" value="{{workGroupForm.description}}" placeholder="请输入工作分工描述" />
        </view>
        <view class="button-row">
          <button class="primary-btn" loading="{{loadingMap.saveWorkGroup}}" bindtap="saveWorkGroup">保存工作分工</button>
          <button class="secondary-btn" bindtap="startCreateWorkGroup">新增工作分工</button>
        </view>
      </view>

      <view class="list-card">
        <view class="list-title">工作分工列表</view>
        <scroll-view class="inner-scroll medium-scroll" scroll-y>
          <view class="list-item list-item-stacked" wx:for="{{workGroupList}}" wx:key="id">
            <view class="list-main">
              <view class="list-name">{{item.name}}</view>
              <view class="list-desc">部门：{{item.departmentName}}</view>
              <view class="list-desc">{{item.description}}</view>
              <view class="inline-actions list-actions-below">
                <text class="link" data-index="{{index}}" bindtap="editWorkGroup">编辑</text>
                <text class="link danger" data-id="{{item.id}}" bindtap="deleteWorkGroup">删除</text>
              </view>
            </view>
          </view>
        </scroll-view>
        <view class="empty-inline" wx:if="{{!workGroupList.length}}">当前没有工作分工数据。</view>
      </view>
    </view>

    <view class="section" wx:if="{{activeTab === 'identities'}}">
      <view class="section-title">身份类别维护</view>
      <view class="edit-box">
        <view class="list-title">{{identityForm.id ? '编辑身份类别' : '新增身份类别'}}</view>
        <view class="field">
          <view class="field-label">身份类别名称</view>
          <input class="field-input" data-field="name" bindinput="onIdentityFieldInput" value="{{identityForm.name}}" placeholder="请输入身份类别名称" />
        </view>
        <view class="field">
          <view class="field-label">身份类别描述</view>
          <textarea class="field-textarea" auto-height maxlength="-1" data-field="description" bindinput="onIdentityFieldInput" value="{{identityForm.description}}" placeholder="请输入身份类别描述" />
        </view>
        <view class="button-row">
          <button class="primary-btn" loading="{{loadingMap.saveIdentity}}" bindtap="saveIdentity">保存身份类别</button>
          <button class="secondary-btn" bindtap="startCreateIdentity">新增身份类别</button>
        </view>
      </view>

      <view class="list-card">
        <view class="list-title">身份类别列表</view>
        <scroll-view class="inner-scroll medium-scroll" scroll-y>
          <view class="list-item list-item-stacked" wx:for="{{identityList}}" wx:key="id">
            <view class="list-main">
              <view class="list-name">{{item.name}}</view>
              <view class="list-desc">{{item.description}}</view>
              <view class="inline-actions list-actions-below">
                <text class="link" data-index="{{index}}" bindtap="editIdentity">编辑</text>
                <text class="link danger" data-id="{{item.id}}" bindtap="deleteIdentity">删除</text>
              </view>
            </view>
          </view>
        </scroll-view>
        <view class="empty-inline" wx:if="{{!identityList.length}}">当前没有身份类别数据。</view>
      </view>
    </view>

    <view class="section" wx:if="{{activeTab === 'settings'}}">
      <view class="section-title">基础配置</view>

      <view class="edit-box" wx:if="{{isRootAdmin}}">
        <view class="list-title">组织管理</view>
        <view class="field" wx:if="{{currentOrganizationId}}">
          <view class="field-label">当前组织</view>
          <view class="field-value">{{currentOrganizationName}}</view>
        </view>
        <view class="button-row compact-row">
          <button class="secondary-btn" bindtap="openOrgForm">新建组织</button>
        </view>
        <view class="list-card nested-card" wx:if="{{organizationList.length}}">
          <view class="list-title">组织列表</view>
          <scroll-view class="inner-scroll small-scroll" scroll-y>
            <view class="list-item list-item-stacked" wx:for="{{organizationList}}" wx:key="id">
              <view class="list-main">
                <view class="list-name">{{item.name}}</view>
                <view class="chip-row">
                  <view class="status-chip current-chip" wx:if="{{item.id === currentOrganizationId}}">当前组织</view>
                </view>
                <view class="inline-actions list-actions-below">
                  <text class="link" data-id="{{item.id}}" data-name="{{item.name}}" bindtap="switchOrganization" wx:if="{{item.id !== currentOrganizationId}}">切换</text>
                  <text class="link" bindtap="openOrgForm" data-id="{{item.id}}">编辑</text>
                  <text class="link danger" data-id="{{item.id}}" bindtap="deleteOrganization" wx:if="{{item.id !== currentOrganizationId}}">删除</text>
                </view>
              </view>
            </view>
          </scroll-view>
        </view>
      </view>

      <view class="edit-box">
        <view class="list-title">时区设置</view>
        <view class="field">
          <view class="field-label">显示时区</view>
          <picker range="{{timezoneOptions}}" range-key="label" value="{{timezoneIndex}}" bindchange="onTimezoneChange">
            <view class="picker-value">{{timezoneOptions[timezoneIndex].label}}</view>
          </picker>
        </view>
        <view class="button-row">
          <button class="primary-btn" loading="{{loadingMap.saveSystemConfig}}" bindtap="saveSystemConfig">保存配置</button>
        </view>
      </view>
    </view>
  </view>

  <view class="popup-mask" wx:if="{{orgFormVisible}}" bindtap="closeOrgForm">
    <view class="popup-card" catchtap="noop">
      <view class="popup-header">
        <view class="list-title">{{orgFormData.id ? '编辑组织名称' : '新建组织'}}</view>
        <text class="popup-close" bindtap="closeOrgForm">关闭</text>
      </view>
      <view class="popup-body">
        <view class="field">
          <view class="field-label">组织名称</view>
          <input class="field-input" bindinput="onOrgFieldInput" value="{{orgFormData.name}}" placeholder="请输入组织名称" />
        </view>
        <view class="button-row compact-row">
          <button class="primary-btn" loading="{{loadingMap.saveOrganization}}" bindtap="saveOrganization">保存组织</button>
          <button class="secondary-btn" wx:if="{{!orgFormData.id}}" loading="{{loadingMap.switchOrganization}}" bindtap="createAndSwitchOrganization">保存并切换</button>
        </view>
      </view>
    </view>
  </view>

  <view class="popup-mask" wx:if="{{scorerTargetPopupVisible}}" bindtap="closeScorerTargetPopup">
    <view class="popup-card completion-popup-card" catchtap="noop">
      <view class="popup-header">
        <view class="popup-title">{{scorerTargetPopupTitle}}</view>
        <text class="popup-close" bindtap="closeScorerTargetPopup">关闭</text>
      </view>
      <view class="popup-loading-overlay" wx:if="{{scorerTargetPopupLoading}}">
        <view class="card-loading-spinner"></view>
      </view>
      <scroll-view class="popup-scroll" scroll-y wx:else>
        <view class="result-table">
          <view class="result-table-head">
            <view class="result-col result-col-target-name">被评人</view>
            <view class="result-col result-col-target-detail">具体信息</view>
            <view class="result-col result-col-popup-status">状态</view>
          </view>
          <view class="result-table-row {{item.status === 'submitted' ? 'result-table-row-clickable' : ''}}" wx:for="{{scorerTargetPopupRows}}" wx:key="targetId" data-record-id="{{item.recordId}}" bindtap="openScorerTargetRecordDetail">
            <view class="result-col result-col-target-name">
              <view class="result-name">{{item.targetName}}</view>
              <view class="result-meta">{{item.targetStudentId}}</view>
            </view>
            <view class="result-col result-col-target-detail">
              <view class="result-meta result-meta-strong">{{item.detailText}}</view>
            </view>
            <view class="result-col result-col-popup-status">
              <view class="status-chip {{item.statusClass}}">{{item.statusText}}</view>
            </view>
          </view>
        </view>
        <view class="empty-inline" wx:if="{{!scorerTargetPopupRows.length}}">该评分人暂无待评任务。</view>
      </scroll-view>
    </view>
  </view>

  <view class="popup-mask" wx:if="{{recordDetailPopupVisible}}" bindtap="closeScoreRecordDetail">
    <view class="popup-card completion-popup-card" catchtap="noop">
      <view class="popup-header">
        <view class="popup-title">评分详情</view>
        <text class="popup-close" bindtap="closeScoreRecordDetail">关闭</text>
      </view>
      <scroll-view class="popup-scroll" scroll-y wx:if="{{recordDetail}}">
        <view class="list-item detail-summary-card">
          <view class="list-main">
            <view class="detail-people-row">
              <view class="detail-person-block">
                <view class="detail-person-label">评分人</view>
                <view class="detail-person-name">{{recordDetail.scorer.name}}</view>
              </view>
              <view class="detail-person-divider"></view>
              <view class="detail-person-block">
                <view class="detail-person-label">被评分人</view>
                <view class="detail-person-name">{{recordDetail.target.name}}</view>
              </view>
            </view>
            <view class="list-desc">{{recordDetail.submittedAt}}</view>
            <view class="detail-action-row">
              <button
                class="secondary-btn danger-btn compact-action-btn"
                data-id="{{recordDetail.recordId}}"
                bindtap="revokeScoreRecord"
              >撤销这条评分</button>
            </view>
          </view>
        </view>
        <view class="question-card" wx:for="{{recordDetail.templates}}" wx:for-index="templateIndex" wx:key="templateId">
          <view class="question-title">{{item.templateName}}</view>
          <view class="detail-tag-row">
            <view class="score-tag score-tag-template">模板得分 {{item.score}}</view>
            <view class="score-tag score-tag-weight">权重 {{item.weight}}</view>
            <view class="score-tag score-tag-weighted">加权 {{item.weightedScore}}</view>
          </view>
          <view class="detail-question compact-question" wx:for="{{item.questions}}" wx:for-item="question" wx:for-index="questionIndex" wx:key="questionIndex">
            <view class="compact-question-head">
              <view class="list-name detail-question-title">{{question.question}}</view>
              <view class="question-score-corner">{{question.score}} / {{question.maxValue}}</view>
            </view>
            <view
              class="score-label-toggle"
              wx:if="{{question.hasScoreLabel}}"
              data-template-index="{{templateIndex}}"
              data-question-index="{{questionIndex}}"
              bindtap="toggleScoreLabel"
            >
              {{question.scoreLabelExpanded ? '收起评分说明' : '查看评分说明'}}
            </view>
            <view class="score-label-box" wx:if="{{question.hasScoreLabel && question.scoreLabelExpanded}}">{{question.scoreLabel}}</view>
          </view>
        </view>
      </scroll-view>
      <view class="card-loading-overlay" wx:if="{{!recordDetail}}">
        <view class="card-loading-spinner"></view>
      </view>
    </view>
  </view>

</view>
