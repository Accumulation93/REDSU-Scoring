          bindscrolltolower="loadMoreScoreResults"
        >
          <view class="list-item list-item-stacked" wx:for="{{hrList}}" wx:key="id">
            <view class="list-main">
              <view class="list-name">{{item.name}} - {{item.identity}}</view>
              <view class="list-desc">{{item.department}} {{item.workGroup}}</view>
              <view class="inline-actions list-actions-below">
