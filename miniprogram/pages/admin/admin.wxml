            <view class="card-loading-spinner"></view>
          </view>
          <block wx:else>
            <view class="result-table">
              <view class="result-table-head">
                <view class="result-col result-col-name">成员</view>
                <view class="result-col result-col-score">得分</view>
                <view class="result-col result-col-progress">已评/应评</view>
              </view>
              <view class="result-table-row" wx:for="{{scoreResultsView.overviewRows}}" wx:key="id" data-target-id="{{item.targetId || item.id}}" bindtap="openTargetScoreRecords">
