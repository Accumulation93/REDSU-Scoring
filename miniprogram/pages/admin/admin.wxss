page {
  min-height: 100%;
  background:
    radial-gradient(circle at 12% 10%, rgba(96, 165, 250, 0.16) 0%, transparent 26%),
    radial-gradient(circle at 86% 18%, rgba(191, 219, 254, 0.22) 0%, transparent 24%),
    radial-gradient(circle at 18% 88%, rgba(125, 211, 252, 0.10) 0%, transparent 22%),
    linear-gradient(135deg, #f8fbff 0%, #f1f6fc 48%, #edf3fa 100%);
  color: #1f2a37;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
}

button,
input,
textarea,
picker,
view,
text,
scroll-view {
  font-family: "PingFang SC", "HarmonyOS Sans SC", "Microsoft YaHei", sans-serif;
}

.page {
  position: relative;
  min-height: 100vh;
  padding: 30rpx 24rpx 42rpx;
  box-sizing: border-box;
}

.page::before {
  content: "";
  position: fixed;
  top: -120rpx;
  right: -90rpx;
  width: 320rpx;
  height: 320rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(96, 165, 250, 0.18) 0%, rgba(96, 165, 250, 0) 72%);
  pointer-events: none;
}

.page::after {
  content: "";
  position: fixed;
  left: -120rpx;
  bottom: 150rpx;
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(147, 197, 253, 0.16) 0%, rgba(147, 197, 253, 0) 72%);
  pointer-events: none;
}

.hero {
  position: relative;
  overflow: hidden;
  margin-bottom: 28rpx;
  padding: 42rpx 34rpx 38rpx;
  border-radius: 38rpx;
  background:
    linear-gradient(135deg, rgba(37, 99, 235, 0.98) 0%, rgba(59, 130, 246, 0.95) 42%, rgba(96, 165, 250, 0.90) 100%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.10), rgba(255, 255, 255, 0));
  border: 1rpx solid rgba(255, 255, 255, 0.24);
  box-shadow:
    0 24rpx 54rpx rgba(37, 99, 235, 0.22),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.24);
  animation: glassFadeUp 0.42s ease both;
}

.hero-admin {
  padding: 40rpx 34rpx 36rpx;
  border-radius: 34rpx;
  background:
    linear-gradient(135deg, rgba(15, 23, 42, 0.96) 0%, rgba(30, 41, 59, 0.96) 42%, rgba(37, 99, 235, 0.92) 100%);
  box-shadow:
    0 26rpx 54rpx rgba(15, 23, 42, 0.22),
    0 0 28rpx rgba(37, 99, 235, 0.08),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.14);
}

.hero-admin::before {
  top: -130rpx;
  right: -56rpx;
  width: 280rpx;
  height: 280rpx;
  background: radial-gradient(circle, rgba(96, 165, 250, 0.30) 0%, rgba(96, 165, 250, 0.06) 46%, rgba(96, 165, 250, 0) 72%);
}

.hero-admin::after {
  content: "";
  position: absolute;
  left: 34rpx;
  right: 34rpx;
  bottom: 20rpx;
  height: 1rpx;
  background: linear-gradient(90deg, rgba(255, 255, 255, 0.16) 0%, rgba(191, 219, 254, 0.34) 52%, rgba(255, 255, 255, 0) 100%);
}

.hero-admin .hero-badge {
  background: linear-gradient(135deg, rgba(59, 130, 246, 0.24) 0%, rgba(148, 163, 184, 0.14) 100%);
  border-color: rgba(191, 219, 254, 0.26);
  box-shadow: 0 10rpx 26rpx rgba(15, 23, 42, 0.12);
}

.hero-admin .hero-title {
  font-size: 46rpx;
  letter-spacing: 0.8rpx;
}

.hero-admin .hero-subtitle {
  color: rgba(241, 245, 249, 0.90);
}

.hero-admin-subtitle {
  margin-top: 16rpx;
  color: #ffffff;
  font-size: 31rpx;
  font-weight: 700;
  line-height: 1.55;
  letter-spacing: 0.4rpx;
}

.tab {
  color: #49627f;
}

.tab-active {
  color: #ffffff;
  background: linear-gradient(135deg, #1d4ed8 0%, #2563eb 58%, #3b82f6 100%);
  box-shadow: 0 16rpx 30rpx rgba(29, 78, 216, 0.22);
}

.section-title,
.list-title {
  color: #10233d;
}

.field-label {
  color: #52647c;
}

.field-input,
.picker-value,
.field-textarea {
  border: 1rpx solid rgba(203, 213, 225, 0.82);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.82),
    0 8rpx 18rpx rgba(15, 23, 42, 0.035);
}

.field-input:focus,
.field-textarea:focus {
  border-color: rgba(59, 130, 246, 0.96);
  box-shadow:
    0 14rpx 28rpx rgba(29, 78, 216, 0.12),
    0 0 0 4rpx rgba(191, 219, 254, 0.62),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
}

.picker-value:active {
  border-color: rgba(59, 130, 246, 0.96);
  box-shadow:
    0 12rpx 24rpx rgba(29, 78, 216, 0.12),
    0 0 0 4rpx rgba(191, 219, 254, 0.52),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
}

.primary-btn {
  background: linear-gradient(135deg, #1d4ed8 0%, #2563eb 58%, #3b82f6 100%);
  box-shadow: 0 16rpx 32rpx rgba(29, 78, 216, 0.20);
}

.secondary-btn {
  color: #1e40af;
  border: 1rpx solid rgba(147, 197, 253, 0.88);
  box-shadow: 0 12rpx 24rpx rgba(29, 78, 216, 0.09);
}

.link,
.pill-link,
.pill-close {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1;
  background: rgba(219, 234, 254, 0.65);
  color: #1d4ed8;
  border: 1rpx solid rgba(147, 197, 253, 0.45);
  transition: transform 0.12s ease, opacity 0.12s ease;
}

.link:active,
.pill-link:active,
.pill-close:active {
  transform: scale(0.94);
  opacity: 0.85;
}

.danger,
.pill-close {
  background: rgba(254, 226, 226, 0.65);
  color: #dc2626;
  border-color: rgba(252, 165, 165, 0.45);
}

.current-chip,
.select-chip {
  color: #1e40af;
  border: 1rpx solid rgba(96, 165, 250, 0.86);
}

.template-section-tip {
  color: #51657f;
  border: 1rpx solid rgba(147, 197, 253, 0.76);
}

.template-hero {
  position: relative;
  overflow: hidden;
  margin-bottom: 22rpx;
  padding: 30rpx 26rpx 28rpx;
  border-radius: 28rpx;
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.88) 0%, rgba(238, 246, 255, 0.78) 100%);
  border: 1rpx solid rgba(219, 234, 254, 0.92);
  box-shadow:
    0 18rpx 38rpx rgba(37, 99, 235, 0.08),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.86);
  animation: glassFadeUp 0.4s ease both;
}

.template-hero::before {
  content: "";
  position: absolute;
  top: -120rpx;
  right: -80rpx;
  width: 260rpx;
  height: 260rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(59, 130, 246, 0.18) 0%, rgba(59, 130, 246, 0) 68%);
  pointer-events: none;
}

.template-hero::after {
  content: "";
  position: absolute;
  left: -60rpx;
  bottom: -90rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(14, 165, 233, 0.12) 0%, rgba(14, 165, 233, 0) 70%);
  pointer-events: none;
}

.template-hero-badge,
.template-hero-title,
.template-hero-desc {
  position: relative;
  z-index: 1;
}

.template-hero-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, rgba(219, 234, 254, 0.98) 0%, rgba(191, 219, 254, 0.9) 100%);
  color: #1d4ed8;
  font-size: 21rpx;
  font-weight: 700;
  box-shadow: 0 10rpx 20rpx rgba(37, 99, 235, 0.08);
}

.template-hero-title {
  margin-top: 16rpx;
  color: #0f172a;
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1.36;
}

.template-hero-desc {
  margin-top: 12rpx;
  color: #5f7289;
  font-size: 24rpx;
  line-height: 1.8;
}

.template-section-head {
  margin-bottom: 14rpx;
}

.template-section-head .list-title {
  margin-bottom: 10rpx;
}

.template-section-tip {
  padding: 14rpx 18rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, rgba(239, 246, 255, 0.92) 0%, rgba(247, 250, 255, 0.84) 100%);
  border: 1rpx solid rgba(191, 219, 254, 0.72);
  color: #5f7289;
  font-size: 22rpx;
  line-height: 1.72;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.82);
}

.template-save-btn {
  position: relative;
  overflow: hidden;
  box-shadow:
    0 18rpx 34rpx rgba(37, 99, 235, 0.18),
    0 0 26rpx rgba(96, 165, 250, 0.16),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.26);
}

.template-save-btn::before {
  content: "";
  position: absolute;
  inset: -24% auto auto -24%;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.24) 0%, rgba(255, 255, 255, 0) 66%);
  pointer-events: none;
}

.hero::before {
  content: "";
  position: absolute;
  top: -90rpx;
  right: -35rpx;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.14);
}

.hero-badge,
.hero-title,
.hero-subtitle {
  position: relative;
  z-index: 1;
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 18rpx;
  padding: 10rpx 24rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.22) 0%, rgba(255, 255, 255, 0.14) 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.28);
  color: #f8fbff;
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.hero-title {
  color: #ffffff;
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.24;
  letter-spacing: 1rpx;
}

.hero-subtitle {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.92);
  font-size: 26rpx;
  line-height: 1.72;
}

.section,
.empty-card {
  position: relative;
  margin-bottom: 24rpx;
  padding: 26rpx 24rpx;
  border-radius: 30rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.82) 0%, rgba(248, 251, 255, 0.74) 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.62);
  box-shadow:
    0 18rpx 36rpx rgba(15, 23, 42, 0.06),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.78);
  backdrop-filter: blur(24rpx);
  -webkit-backdrop-filter: blur(24rpx);
  box-sizing: border-box;
  transition: transform 0.22s ease, box-shadow 0.28s ease, border-color 0.24s ease;
  animation: glassFadeUp 0.46s ease both;
}

.empty-card {
  text-align: center;
  padding-top: 64rpx;
  padding-bottom: 64rpx;
}

.tabs {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 22rpx;
}

.tab {
  padding: 16rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.74);
  border: 1rpx solid rgba(255, 255, 255, 0.54);
  color: #53687f;
  font-size: 24rpx;
  font-weight: 600;
  box-shadow: 0 10rpx 22rpx rgba(15, 23, 42, 0.04);
  transition: transform 0.18s ease, box-shadow 0.22s ease, background 0.22s ease, color 0.22s ease;
}

.tab-active {
  color: #ffffff;
  background: linear-gradient(135deg, #2563eb 0%, #60a5fa 100%);
  box-shadow: 0 16rpx 30rpx rgba(37, 99, 235, 0.18);
}

.tab:active {
  transform: translateY(1rpx) scale(0.985);
}

.section-title,
.list-title {
  position: relative;
  padding-left: 18rpx;
  margin-bottom: 18rpx;
  color: #0f172a;
  font-size: 30rpx;
  font-weight: 700;
}

.section-title::before,
.list-title::before {
  content: "";
  position: absolute;
  left: 0;
  top: 8rpx;
  width: 8rpx;
  height: 28rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #2563eb 0%, #60a5fa 100%);
  box-shadow: 0 0 14rpx rgba(59, 130, 246, 0.24);
}

.field {
  margin-bottom: 16rpx;
}

.field-row {
  display: flex;
  gap: 16rpx;
}

.field-half {
  flex: 1;
  min-width: 0;
}

.field-label {
  margin-bottom: 10rpx;
  color: #64748b;
  font-size: 22rpx;
  line-height: 1.5;
}

.field-input,
.picker-value,
.field-textarea {
  width: 100%;
  box-sizing: border-box;
  border-radius: 22rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.92) 0%, rgba(247, 250, 255, 0.82) 100%);
  border: 1rpx solid rgba(226, 232, 240, 0.68);
  color: #0f172a;
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.78),
    0 8rpx 18rpx rgba(15, 23, 42, 0.03);
  transition: box-shadow 0.22s ease, border-color 0.22s ease, background 0.22s ease;
}

.field-input,
.picker-value {
  min-height: 88rpx;
  padding: 0 24rpx;
  font-size: 26rpx;
  display: flex;
  align-items: center;
}

.field-textarea {
  min-height: 160rpx;
  padding: 22rpx 24rpx;
  font-size: 26rpx;
}

.field-input:focus,
.field-textarea:focus {
  border-color: rgba(96, 165, 250, 0.92);
  box-shadow:
    0 14rpx 28rpx rgba(37, 99, 235, 0.10),
    0 0 0 4rpx rgba(191, 219, 254, 0.55),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
}

.picker-value:active {
  transform: translateY(1rpx) scale(0.992);
  border-color: rgba(96, 165, 250, 0.92);
  box-shadow:
    0 12rpx 24rpx rgba(37, 99, 235, 0.10),
    0 0 0 4rpx rgba(191, 219, 254, 0.48),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
}

.question-textarea {
  min-height: 120rpx;
  white-space: pre-wrap;
}

.button-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin: 18rpx 0;
}

.compact-row {
  margin-top: 10rpx;
}

.primary-btn,
.secondary-btn {
  flex: 1 1 280rpx;
  min-width: 220rpx;
  min-height: 84rpx;
  border-radius: 999rpx;
  line-height: 84rpx;
  font-size: 24rpx;
  font-weight: 700;
  transition: box-shadow 0.24s ease, opacity 0.18s ease, filter 0.24s ease;
}

.primary-btn {
  color: #ffffff;
  background: linear-gradient(135deg, #2563eb 0%, #60a5fa 100%);
  box-shadow: 0 16rpx 32rpx rgba(37, 99, 235, 0.18);
}

.secondary-btn {
  color: #1d4ed8;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.92) 0%, rgba(235, 243, 255, 0.86) 100%);
  border: 1rpx solid rgba(191, 219, 254, 0.8);
  box-shadow: 0 12rpx 24rpx rgba(37, 99, 235, 0.08);
}

.primary-btn:active,
.secondary-btn:active {
  transform: translateY(2rpx) scale(0.986);
  filter: saturate(1.03);
}

.edit-box,
.list-card {
  margin-top: 18rpx;
  padding: 20rpx;
  border-radius: 26rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.72) 0%, rgba(247, 250, 255, 0.62) 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.62);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.78),
    0 12rpx 26rpx rgba(15, 23, 42, 0.04);
  transition: transform 0.22s ease, box-shadow 0.28s ease, border-color 0.24s ease, background 0.24s ease;
  animation: glassFadeUp 0.48s ease both;
}

.edit-box:active,
.list-card:active {
  transform: translateY(1rpx) scale(0.995);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.82),
    0 16rpx 32rpx rgba(37, 99, 235, 0.08);
}

.nested-card {
  margin-top: 10rpx;
}

.rule-panel {
  margin-top: 18rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.86) 0%, rgba(248, 251, 255, 0.74) 100%);
  border: 1rpx solid rgba(219, 234, 254, 0.72);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.82),
    0 14rpx 30rpx rgba(15, 23, 42, 0.05);
  box-sizing: border-box;
}

.rule-panel:first-child {
  margin-top: 0;
}

.rule-panel-head {
  margin-bottom: 18rpx;
}

.rule-panel-head-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 18rpx;
}

.rule-panel-title {
  position: relative;
  padding-left: 18rpx;
  color: #0f172a;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.35;
}

.rule-panel-title::before {
  content: "";
  position: absolute;
  left: 0;
  top: 7rpx;
  width: 8rpx;
  height: 28rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #2563eb 0%, #60a5fa 100%);
  box-shadow: 0 0 14rpx rgba(59, 130, 246, 0.24);
}

.rule-panel-subtitle {
  margin-top: 6rpx;
  color: #64748b;
  font-size: 22rpx;
  line-height: 1.6;
}

.mini-action-btn {
  flex-shrink: 0;
  min-width: 190rpx;
  padding-left: 18rpx;
  padding-right: 18rpx;
}

.rule-switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 14rpx;
  padding: 18rpx;
  border-radius: 18rpx;
  background: rgba(248, 250, 252, 0.82);
  border: 1rpx solid rgba(226, 232, 240, 0.86);
}

.rule-empty {
  padding: 24rpx 20rpx;
  border-radius: 20rpx;
  color: #64748b;
  font-size: 24rpx;
  text-align: center;
  background: rgba(248, 250, 252, 0.74);
  border: 1rpx dashed rgba(148, 163, 184, 0.56);
}

.small-empty {
  margin-top: 14rpx;
  padding: 16rpx;
  font-size: 22rpx;
}

.rule-clause-card,
.template-config-card {
  margin-bottom: 16rpx;
  padding: 20rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.96) 0%, rgba(249, 251, 255, 0.88) 100%);
  border: 1rpx solid rgba(226, 237, 247, 0.96);
  box-shadow:
    0 12rpx 26rpx rgba(15, 23, 42, 0.045),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.84);
  box-sizing: border-box;
}

.rule-clause-card:last-child,
.template-config-card:last-child {
  margin-bottom: 0;
}

.rule-clause-title {
  color: #0f172a;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.45;
}

.rule-tag-row,
.rule-template-tags,
.template-config-meta,
.rule-list-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.rule-tag-row {
  margin-top: 12rpx;
}

.rule-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 38rpx;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 1.35;
  border: 1rpx solid transparent;
}

.tag-scope {
  color: #1d4ed8;
  background: rgba(219, 234, 254, 0.76);
  border-color: rgba(147, 197, 253, 0.64);
}

.tag-target {
  color: #7c3aed;
  background: rgba(237, 233, 254, 0.78);
  border-color: rgba(196, 181, 253, 0.64);
}

.tag-required {
  color: #b45309;
  background: rgba(254, 243, 199, 0.82);
  border-color: rgba(251, 191, 36, 0.52);
}

.tag-free {
  color: #047857;
  background: rgba(209, 250, 229, 0.78);
  border-color: rgba(110, 231, 183, 0.58);
}

.tag-weight {
  color: #166534;
  background: rgba(220, 252, 231, 0.78);
  border-color: rgba(134, 239, 172, 0.56);
}

.tag-order {
  color: #0f766e;
  background: rgba(204, 251, 241, 0.72);
  border-color: rgba(94, 234, 212, 0.52);
}

.rule-template-list {
  display: grid;
  gap: 12rpx;
  margin-top: 16rpx;
}

.rule-template-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  width: 100%;
  padding: 16rpx 18rpx;
  border-radius: 18rpx;
  background: rgba(248, 250, 252, 0.86);
  border: 1rpx solid rgba(226, 232, 240, 0.84);
  box-sizing: border-box;
}

.rule-template-name,
.template-config-name {
  flex: 1;
  min-width: 0;
  color: #0f172a;
  font-size: 25rpx;
  font-weight: 700;
  line-height: 1.45;
  word-break: break-word;
}

.rule-card-actions,
.template-config-actions {
  width: 100%;
  justify-content: flex-start;
  margin-top: 16rpx;
  gap: 20rpx;
}

.rule-config-list {
  margin-top: 18rpx;
}

