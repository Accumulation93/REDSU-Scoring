  font-size: 22rpx;
  line-height: 1.7;
  white-space: pre-wrap;
}

.status-muted {
  color: #64748b;
  background: rgba(148, 163, 184, 0.16);
}

.status-inactive {
  color: #7c3aed;
  background: rgba(139, 92, 246, 0.15);
}

.result-col-popup-name {
  flex: 1.35;
  min-width: 0;
}

.result-col-popup-detail {
  flex: 1.35;
  min-width: 0;
}

.result-col-target-name {
  flex: 0.9;
  min-width: 0;
}

.result-col-target-detail {
  flex: 1.8;
  min-width: 0;
}

.result-col-popup-progress {
  flex: 0.85;
  min-width: 160rpx;
}

.result-col-popup-status {
  width: 100rpx;
}

.result-meta-strong {
  color: #334155;
  font-weight: 600;
}

.status-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 48rpx;
  padding: 4rpx 8rpx;
  border-radius: 999rpx;
  font-size: 19rpx;
  font-weight: 700;
  line-height: 1.1;
}

.status-pending {
  color: #b45309;
  background: rgba(251, 191, 36, 0.16);
}

.status-completed {
  color: #15803d;
  background: rgba(34, 197, 94, 0.14);
}

.tab {
  color: #49627f;
}

.tab-active {
  color: #ffffff;
  background: linear-gradient(135deg, #1d4ed8 0%, #2563eb 58%, #3b82f6 100%);
  box-shadow: 0 16rpx 30rpx rgba(29, 78, 216, 0.22);
}

.section-title,
.list-title {
  color: #10233d;
}

.field-label {
  color: #52647c;
}

.field-input,
.picker-value,
.field-textarea {
  border: 1rpx solid rgba(203, 213, 225, 0.82);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.82),
    0 8rpx 18rpx rgba(15, 23, 42, 0.035);
}

.field-input:focus,
.field-textarea:focus {
  border-color: rgba(59, 130, 246, 0.96);
  box-shadow:
    0 14rpx 28rpx rgba(29, 78, 216, 0.12),
    0 0 0 4rpx rgba(191, 219, 254, 0.62),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
}

.picker-value:active {
  border-color: rgba(59, 130, 246, 0.96);
  box-shadow:
    0 12rpx 24rpx rgba(29, 78, 216, 0.12),
    0 0 0 4rpx rgba(191, 219, 254, 0.52),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
}

.primary-btn {
  background: linear-gradient(135deg, #1d4ed8 0%, #2563eb 58%, #3b82f6 100%);
  box-shadow: 0 16rpx 32rpx rgba(29, 78, 216, 0.20);
}

.secondary-btn {
  color: #1e40af;
  border: 1rpx solid rgba(147, 197, 253, 0.88);
  box-shadow: 0 12rpx 24rpx rgba(29, 78, 216, 0.09);
}

.current-chip,
.select-chip {
  color: #1e40af;
  border: 1rpx solid rgba(96, 165, 250, 0.86);
}

.template-section-tip {
  color: #51657f;
  border: 1rpx solid rgba(147, 197, 253, 0.76);
}

@media (max-width: 360px) {
  .hero-admin {
    padding: 34rpx 28rpx 30rpx;
  }

  .hero-admin .hero-title {
    font-size: 42rpx;
  }

  .hero-admin-subtitle {
    font-size: 27rpx;
  }
}

.filter-loading-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 16rpx;
  padding: 14rpx 18rpx;
  border-radius: 18rpx;
  background: rgba(239, 246, 255, 0.82);
  border: 1rpx solid rgba(147, 197, 253, 0.42);
}

.filter-loading-spinner {
  width: 28rpx;
  height: 28rpx;
  border: 4rpx solid rgba(37, 99, 235, 0.18);
  border-top-color: #2563eb;
  border-radius: 50%;
  animation: adminSpin 0.7s linear infinite;
}

.filter-loading-text {
  color: #2563eb;
  font-size: 24rpx;
  font-weight: 500;
}

.card-loading-overlay {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx 0;
}

.popup-loading-overlay {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48rpx 0;
  gap: 18rpx;
}

.card-loading-spinner {
  width: 40rpx;
  height: 40rpx;
  border: 5rpx solid rgba(37, 99, 235, 0.16);
  border-top-color: #2563eb;
  border-radius: 50%;
  animation: adminSpin 0.7s linear infinite;
}

@keyframes adminSpin {
  to { transform: rotate(360deg); }
}
